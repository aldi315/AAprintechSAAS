generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================= ENUMS =======================

enum Role {
  SUPER_ADMIN // Akses penuh ke seluruh platform
  RESELLER // Pemilik reseller/bisnis
}

enum SubscriptionStatus {
  INACTIVE
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPackage {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AttendanceStatus {
  UNKNOWN
  ATTENDING
  NOT_ATTENDING
}

enum WeddingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ======================= MODELS =======================

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String? // Optional untuk OAuth (Google, dll)
  avatar   String?
  role     Role    @default(RESELLER)

  // Relations
  ownedResellers Reseller[] @relation("ResellerOwner")

  // Timestamps & Soft Delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model Reseller {
  id                 String             @id @default(cuid())
  businessName       String
  slug               String             @unique
  customDomain       String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)

  // Settings JSON: branding, WA template, logo, custom color, dll
  // Struktur: { "logo": "url", "primaryColor": "#hex", "waTemplate": "...", "customDomain": "..." }
  settings Json @default("{}")

  ownerId String
  owner   User   @relation("ResellerOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Reseller-specific Relations
  weddings      Wedding[]
  subscriptions Subscription[]
  payments      Payment[]
  media         Media[]
  activityLogs  ActivityLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([customDomain])
  @@index([ownerId])
}

model Wedding {
  id         String        @id @default(cuid())
  resellerId String
  slug       String        @unique
  status     WeddingStatus @default(DRAFT)
  timezone   String        @default("Asia/Jakarta")
  brideName  String
  groomName  String
  location   String?       @db.Text
  mapsUrl    String?
  musicUrl   String?
  coverImage String?
  gallery    Json          @default("[]") // Array of { url: string, caption?: string }
  viewCount  Int           @default(0) // Counter view link undangan

  // SEO / OG Fields — penting untuk sharing via WhatsApp
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // Visual/Widget overrides per wedding
  customConfig    Json          @default("{}")

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Restrict)
  reseller   Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  events WeddingEvent[] // Multi-event: akad, resepsi, ngunduh mantu
  guests InvitationGuest[]
  rsvps  RSVP[]
  media  Media[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([resellerId])
  @@index([slug])
  @@index([status])
}

model WeddingEvent {
  id        String    @id @default(cuid())
  weddingId String
  name      String // "Akad Nikah", "Resepsi", "Ngunduh Mantu"
  startTime DateTime
  endTime   DateTime?
  location  String?   @db.Text
  mapsUrl   String?
  dresscode String?
  note      String?   @db.Text

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}

model TemplateCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  
  templates Template[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id           String  @id @default(cuid())
  name         String
  categoryId   String
  previewImage String?
  themeConfig  Json    @default("{}") // Konfigurasi warna, font, layout
  price        Int     @default(0)
  active       Boolean @default(true)

  category     TemplateCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  weddings     Wedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvitationGuest {
  id               String           @id @default(cuid())
  weddingId        String
  guestName        String
  phone            String?
  guestCode        String           @unique // Kode unik. URL dibentuk runtime: domain/slug?to=guestCode
  qrCode           String? // QR image URL (generated dari guestCode)
  attendanceStatus AttendanceStatus @default(UNKNOWN)

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  rsvps   RSVP[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
  @@index([guestCode])
}

model RSVP {
  id         String           @id @default(cuid())
  weddingId  String
  guestId    String? // Nullable jika tamu tidak pre-generated
  attendance AttendanceStatus
  message    String?          @db.Text
  totalGuest Int              @default(1)

  // Anti-spam fields — track origin request
  ipAddress String?
  userAgent String?

  wedding Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guest   InvitationGuest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
  @@index([guestId])
}

model Subscription {
  id            String              @id @default(cuid())
  resellerId    String
  package       SubscriptionPackage @default(FREE) // Enum, bukan String
  startDate     DateTime
  endDate       DateTime
  paymentStatus PaymentStatus       @default(PENDING)

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resellerId])
}

model Payment {
  id         String        @id @default(cuid())
  resellerId String
  provider   String // midtrans, xendit, dll
  externalId String // ID transaksi dari payment gateway
  amount     Decimal       @db.Decimal(12, 2)
  status     PaymentStatus @default(PENDING)
  payload    Json // Raw callback body dari payment gateway

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resellerId])
  @@index([externalId])
}

model Media {
  id        String  @id @default(cuid())
  resellerId String
  weddingId String? // Optional, if uploaded contextually for a wedding
  provider  String // s3, cloudinary, local, supabase, dll
  fileUrl   String
  fileType  String // image/jpeg, video/mp4, dll
  size      Int // bytes

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  wedding  Wedding? @relation(fields: [weddingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([resellerId])
  @@index([weddingId])
}

model ActivityLog {
  id         String @id @default(cuid())
  resellerId String
  action     String // "RESELLER_REGISTERED", "WEDDING_PUBLISHED", "RSVP_SUBMITTED"
  metadata   Json // userId, ip, field changes, dll

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([resellerId])
}

